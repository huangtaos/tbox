  "scripts": {
    "dev": "node -e \"const { spawn } = require('child_process'); const args = process.argv.slice(1).filter(a => !a.includes('node_modules') && !a.startsWith('-e') && a !== '--host' && a !== '0.0.0.0'); spawn('npx', ['next', 'dev', '-H', '0.0.0.0', ...args], { stdio: 'inherit', shell: true });\"",
